<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.his.mapper.ModuleBackfillMapper">

    <select id="selectTableColumns" resultType="map">
        select column_name as name, data_type as dataType
        from information_schema.columns
        where table_schema = database()
          and table_name = #{tableName}
        order by ordinal_position
    </select>

    <select id="countRows" resultType="long">
        select count(1) from `${table}`
    </select>

    <select id="selectPageRows" resultType="map">
        select * from `${table}` order by id desc limit #{limit} offset #{offset}
    </select>

    <insert id="insertRow">
        insert into `${table}`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="writable" item="c" separator=",">
                `${c}`
            </foreach>
        </trim>
        values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <foreach collection="writable" item="c" separator=",">
                #{body[c]}
            </foreach>
        </trim>
    </insert>

    <select id="selectLastInsertId" resultType="long">
        select last_insert_id()
    </select>

    <update id="updateRow">
        update `${table}`
        <set>
            <foreach collection="writable" item="c" separator=",">
                `${c}` = #{body[c]}
            </foreach>
        </set>
        where id = #{id}
    </update>

    <delete id="deleteRow">
        delete from `${table}` where id = #{id}
    </delete>
</mapper>
