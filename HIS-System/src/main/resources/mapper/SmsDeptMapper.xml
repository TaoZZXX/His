<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.his.mapper.SmsDeptMapper">

    <sql id="DeptColumns">
        id, code, cat_id AS catId, name, type, status
    </sql>

    <sql id="PageWhere">
        <where>
            <if test="code != null and code != ''">
                AND code LIKE CONCAT('%', #{code}, '%')
            </if>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="catId != null">
                AND cat_id = #{catId}
            </if>
            <if test="type != null">
                AND type = #{type}
            </if>
        </where>
    </sql>

    <select id="selectDeptById" resultType="com.his.domain.SmsDept">
        SELECT <include refid="DeptColumns"/> FROM sms_dept WHERE id = #{id}
    </select>

    <select id="selectAllDepts" resultType="com.his.domain.SmsDept">
        SELECT <include refid="DeptColumns"/>
        FROM sms_dept
        WHERE (status IS NULL OR status = 1)
        ORDER BY id
    </select>

    <select id="selectByPage" resultType="com.his.domain.SmsDept">
        SELECT <include refid="DeptColumns"/>
        FROM sms_dept
        <include refid="PageWhere"/>
        ORDER BY id ASC
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByPage" resultType="long">
        SELECT COUNT(1) FROM sms_dept
        <include refid="PageWhere"/>
    </select>

    <select id="countByCode" resultType="int">
        SELECT COUNT(1) FROM sms_dept
        WHERE code = #{code}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

    <insert id="insert" parameterType="com.his.domain.SmsDept" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sms_dept (code, cat_id, name, type, status)
        VALUES (#{code}, #{catId}, #{name}, #{type}, #{status})
    </insert>

    <update id="updateById" parameterType="com.his.domain.SmsDept">
        UPDATE sms_dept
        <set>
            <if test="code != null">code = #{code},</if>
            <if test="catId != null">cat_id = #{catId},</if>
            <if test="name != null">name = #{name},</if>
            <if test="type != null">type = #{type},</if>
            <if test="status != null">status = #{status},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM sms_dept WHERE id = #{id}
    </delete>

    <delete id="deleteByIds">
        DELETE FROM sms_dept WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="countStaffByDeptId" resultType="int">
        SELECT COUNT(1) FROM sms_staff WHERE dept_id = #{deptId}
    </select>
</mapper>
