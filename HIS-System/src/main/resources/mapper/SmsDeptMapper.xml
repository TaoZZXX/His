<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.his.mapper.SmsDeptMapper">

    <select id="selectDeptById" resultType="com.his.domain.SmsDept">
        select * from sms_dept where id = #{id}
    </select>

    <!-- 新增：查询所有科室 -->
    <select id="selectAllDepts" resultType="com.his.domain.SmsDept">
        select * from sms_dept order by id
    </select>

</mapper>