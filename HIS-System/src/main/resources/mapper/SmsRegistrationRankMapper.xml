<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.his.mapper.SmsRegistrationRankMapper">

    <resultMap id="BaseMap" type="com.his.domain.SmsRegistrationRank">
        <id column="id" property="id"/>
        <result column="code" property="code"/>
        <result column="name" property="name"/>
        <result column="seq_no" property="seqNo"/>
        <result column="price" property="price"/>
        <result column="status" property="status"/>
    </resultMap>

    <select id="selectById" resultMap="BaseMap">
        SELECT id, code, name, seq_no, price, status
        FROM sms_registration_rank
        WHERE id = #{id}
    </select>

    <select id="selectAllEnabled" resultMap="BaseMap">
        SELECT id, code, name, seq_no, price, status
        FROM sms_registration_rank
        WHERE status = 1
        ORDER BY seq_no ASC, id ASC
    </select>
</mapper>
