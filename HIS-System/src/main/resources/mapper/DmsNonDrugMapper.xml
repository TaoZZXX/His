<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.his.mapper.DmsNonDrugMapper">

    <select id="selectEnabledByTypeAndKeyword" resultType="com.his.domain.DmsNonDrug">
        select *
        from dms_non_drug
        where status = 1
          and record_type = #{type}
        <if test="keyword != null and keyword != ''">
            and (name like concat('%', #{keyword}, '%')
                or code like concat('%', #{keyword}, '%')
                or mnemonic_code like concat('%', #{keyword}, '%'))
        </if>
        order by name
    </select>

    <select id="selectById" resultType="com.his.domain.DmsNonDrug">
        select *
        from dms_non_drug
        where id = #{id}
    </select>

</mapper>

